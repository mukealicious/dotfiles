{
  "theme": "gruvbox-dark",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 5
  },
  "skills": [
    "~/.dotfiles/.ai-runtime/pi/skills"
  ],
  "packages": [
    "~/.dotfiles/pi/packages/pi-exa",
    "git:https://github.com/HazAT/pi-parallel",
    "~/.dotfiles/pi/packages/pi-openai-fast",
    "~/.dotfiles/pi/packages/pi-subagents",
    {
      "source": "npm:mitsupi",
      "skills": [
        "-skills/frontend-design/SKILL.md",
        "-skills/librarian/SKILL.md"
      ]
    }
  ],
  "lastChangelogVersion": "0.74.0",
  "hideThinkingBlock": false
}