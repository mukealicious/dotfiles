{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "app": {
    "appearance": "system"
  },

  "browser": {
    "theme": "system"
  },

  "workspaceColors": {
    "indicatorStyle": "leftRail",
    "colors": {
      "Gruvbox Red": "#9D0006",
      "Gruvbox Orange": "#AF3A03",
      "Gruvbox Yellow": "#B57614",
      "Gruvbox Green": "#79740E",
      "Gruvbox Aqua": "#427B58",
      "Gruvbox Blue": "#076678",
      "Gruvbox Purple": "#8F3F71",
      "Gruvbox Brown": "#7C6F64",
      "Gruvbox Dark Red": "#CC241D",
      "Gruvbox Dark Orange": "#D65D0E",
      "Gruvbox Dark Yellow": "#D79921",
      "Gruvbox Dark Green": "#98971A",
      "Gruvbox Dark Aqua": "#689D6A",
      "Gruvbox Dark Blue": "#458588",
      "Gruvbox Dark Purple": "#B16286",
      "Gruvbox Dark Gray": "#928374"
    }
  },

  "sidebarAppearance": {
    "matchTerminalBackground": false,
    "tintColor": "#928374",
    "lightModeTintColor": "#FBF1C7",
    "darkModeTintColor": "#282828",
    "tintOpacity": 0.18
  }
}
