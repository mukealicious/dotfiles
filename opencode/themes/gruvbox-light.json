      "dark": "blue",
      "light": "blue"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxPunctuation": {
      "dark": "fg2",
      "light": "fg2"
