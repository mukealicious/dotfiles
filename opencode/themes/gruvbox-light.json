{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#fbf1c7",
    "bg1": "#ebdbb2",
    "bg2": "#d5c4a1",
    "fg": "#3c3836",
    "fg1": "#504945",
    "fg2": "#665c54",
    "fg3": "#7c6f64",
    "red": "#9d0006",
    "green": "#79740e",
    "yellow": "#b57614",
    "blue": "#076678",
    "purple": "#8f3f71",
    "aqua": "#427b58",
    "orange": "#af3a03",
    "gray": "#928374",
    "successBg": "#dde6c4",
    "errorBg": "#ebd5c4",
    "diffBg": "#f2e5bc"
  },
  "theme": {
