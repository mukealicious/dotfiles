#!/usr/bin/env bash
#
# bootstrap installs things.

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

set -e

. "$DOTFILES_ROOT/lib/log.sh"

echo ''

# Install dotfiles symlinks (interactive mode for bootstrap)
export SYMLINK_INTERACTIVE=true
"$DOTFILES_ROOT/script/symlink"

# If we're on a Mac, let's install and setup dependencies.
if [ "$(uname -s)" = "Darwin" ]
then
  log_info "installing dependencies"
  if bin/dot | while read -r data; do log_info "$data"; done
  then
    log_success "dependencies installed"
  else
    log_error "error installing dependencies"
    echo ''
    exit 1
  fi
fi

echo ''
echo '  All installed!'
