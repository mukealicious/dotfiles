#!/bin/sh

set -e

PI_BIN="$HOME/.bun/bin/pi"

if [ ! -x "$PI_BIN" ]; then
  echo "pi: expected binary at $PI_BIN" >&2
  exit 1
fi

if [ -n "${OPENAI_API_KEY:-}" ]; then
  exec "$PI_BIN" "$@"
fi

if [ -z "${OPENAI_OP_REF:-}" ]; then
  exec "$PI_BIN" "$@"
fi

if ! command -v op >/dev/null 2>&1; then
  echo "pi: 1Password CLI 'op' is not installed" >&2
  exit 1
fi

OPENAI_API_KEY="$(op read "$OPENAI_OP_REF")" || {
  echo "pi: failed to load OPENAI_API_KEY from 1Password via OPENAI_OP_REF" >&2
  exit 1
}

if [ -z "$OPENAI_API_KEY" ]; then
  echo "pi: OPENAI_OP_REF returned an empty secret" >&2
  exit 1
fi

export OPENAI_API_KEY
exec "$PI_BIN" "$@"
