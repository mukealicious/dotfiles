#!/bin/sh
# Open files in the preferred code editor.
# Default: Zed. Fallback: VS Code. Last resort: platform text editor/vi.

set -e

wait=false
if [ "${1:-}" = "--wait" ]; then
  wait=true
  shift
fi

if command -v zed >/dev/null 2>&1; then
  if [ "$wait" = "true" ]; then
    exec zed --wait "$@"
  fi
  exec zed "$@"
fi

if command -v code >/dev/null 2>&1; then
  if [ "$wait" = "true" ]; then
    exec code --wait "$@"
  fi
  exec code "$@"
fi

if [ "$wait" = "true" ]; then
  exec vi "$@"
fi

if command -v open >/dev/null 2>&1; then
  exec open -e "$@"
fi

exec vi "$@"
