#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]:-$0}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
	echo "dot -- dotfiles management"
	echo ""
	echo "Usage: dot [command] [options]"
	echo ""
	echo "Commands:"
	echo "  doctor      Run environment diagnostics"
	echo ""
	echo "Options:"
	echo "  -e, --edit  Open dotfiles directory for editing"
	echo "  -h, --help  Show this help message and exit"
	exit
}

case "${1:-}" in
	doctor)
		shift
		exec "$dotfilesDirectory/bin/dot-doctor" "$@"
		;;
	-e|--edit)
		exec "$EDITOR" "$dotfilesDirectory"
		;;
	-h|--help)
		displayUsageAndExit
		;;
	"")
		;; # fall through to update logic
	*)
		echo "Unknown command: $1"
		displayUsageAndExit
		;;
esac

export DOTFILES=$HOME/.dotfiles

# Update symlinks (non-interactive, skips conflicts)
$DOTFILES/script/symlink

# Set macOS defaults
$DOTFILES/macos/set-defaults.sh

# Install homebrew
$DOTFILES/homebrew/install.sh 2>&1

# Upgrade homebrew
echo "› brew update"
brew update

echo "› brew upgrade"
brew upgrade

# Install from Brewfile
echo "› brew bundle"
brew bundle --file="$DOTFILES/Brewfile"

# Install software
echo "› $DOTFILES/script/install"
$DOTFILES/script/install
