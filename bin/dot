#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "$0" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

. "$dotfilesDirectory/lib/log.sh"

displayUsageAndExit() {
  echo "dot -- dotfiles management"
  echo ""
  echo "Usage: dot [command] [options]"
  echo ""
  echo "Commands:"
  echo "  doctor      Run environment diagnostics"
  echo ""
  echo "Options:"
  echo "  --force     Back up and replace managed symlink conflicts"
  echo "  -e, --edit  Open dotfiles directory for editing"
  echo "  -h, --help  Show this help message and exit"
  exit
}

run_step() {
  label="$1"
  shift
  log_step "$label"
  "$@"
}

optional_failures=""

run_optional_step() {
  label="$1"
  shift
  log_step "$label"
  if ! "$@"; then
    log_warn "$label failed; continuing with remaining installers"
    optional_failures="${optional_failures}
$label"
  fi
}

ensure_brew_available() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  fi

  if ! command -v brew >/dev/null 2>&1; then
    log_error "Homebrew installed but brew is not available on PATH"
    log_hint "Open a new shell or add Homebrew's shellenv to your shell config, then re-run dot"
    exit 1
  fi
}

open_dotfiles_for_editing() {
  if [ -n "${EDITOR:-}" ]; then
    exec "$EDITOR" "$dotfilesDirectory"
  fi

  exec open "$dotfilesDirectory"
}

force_symlinks=false

case "${1:-}" in
  doctor)
    shift
    exec "$dotfilesDirectory/bin/dot-doctor" "$@"
    ;;
  -e|--edit)
    open_dotfiles_for_editing
    ;;
  --force)
    force_symlinks=true
    shift
    ;;
  -h|--help)
    displayUsageAndExit
    ;;
  "")
    ;;
  *)
    echo "Unknown command: $1"
    displayUsageAndExit
    ;;
esac

if [ "$#" -gt 0 ]; then
  echo "Unknown argument: $1"
  displayUsageAndExit
fi

log_section "Symlinks"
if [ "$force_symlinks" = "true" ]; then
  run_step "$dotfilesDirectory/script/symlink --force --non-interactive" env FORCE=true "$dotfilesDirectory/script/symlink" --force --non-interactive
else
  run_step "$dotfilesDirectory/script/symlink --non-interactive" env FORCE=false "$dotfilesDirectory/script/symlink" --non-interactive
fi

log_section "macOS defaults"
run_step "$dotfilesDirectory/macos/set-defaults.sh" "$dotfilesDirectory/macos/set-defaults.sh"

log_section "Homebrew"
run_step "$dotfilesDirectory/homebrew/install.sh" "$dotfilesDirectory/homebrew/install.sh"
ensure_brew_available
run_step "brew update" brew update
run_optional_step "brew upgrade" brew upgrade
run_step "brew bundle --file=$dotfilesDirectory/Brewfile" brew bundle --file="$dotfilesDirectory/Brewfile"

log_section "Topic installers"
if [ "$force_symlinks" = "true" ]; then
  run_step "$dotfilesDirectory/script/install --skip ./homebrew/install.sh --force" env FORCE=true "$dotfilesDirectory/script/install" --skip ./homebrew/install.sh --force
else
  run_step "$dotfilesDirectory/script/install --skip ./homebrew/install.sh" env FORCE=false "$dotfilesDirectory/script/install" --skip ./homebrew/install.sh
fi

if [ -n "$optional_failures" ]; then
  log_warn "Completed with non-blocking failures:${optional_failures}"
else
  printf '\n%sDone.%s %sDotfiles are up to date.%s\n' "$LOG_GREEN" "$LOG_RESET" "$LOG_DIM" "$LOG_RESET"
fi
